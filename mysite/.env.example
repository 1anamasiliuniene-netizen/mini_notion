# Django Settings
# Copy this file to .env and set real values for production

# ===== CRITICAL PRODUCTION SETTINGS =====

# Secret Key (CHANGE THIS IN PRODUCTION - use a strong random string)
# Generate new key: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=replace-with-new-secret-key-for-production

# Debug Mode (MUST be 0 in production!)
DJANGO_DEBUG=0

# Allowed Hosts (comma-separated, e.g., yourdomain.pythonanywhere.com,www.yourdomain.com)
DJANGO_ALLOWED_HOSTS=yourdomain.pythonanywhere.com

# CSRF Trusted Origins (https:// required for production)
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.pythonanywhere.com

# Force HTTPS (should be 1 in production)
DJANGO_FORCE_SSL=1

# ===== DATABASE CONFIGURATION =====

# Optional: PostgreSQL connection string
# If not set, falls back to SQLite3 (db.sqlite3)
# Example: postgresql://username:password@hostname:5432/dbname
DATABASE_URL=

# Database SSL requirement (1 for production)
DJANGO_DB_SSL_REQUIRE=1

# Database connection max age in seconds
DJANGO_DB_CONN_MAX_AGE=600

# ===== SECURITY SETTINGS =====

# HSTS (HTTP Strict Transport Security) max age in seconds
DJANGO_SECURE_HSTS_SECONDS=31536000

# ===== EXTERNAL API SETTINGS =====

# NASA API Key (get from https://api.nasa.gov/)
# If not provided, uses DEMO_KEY (limited requests)
NASA_API_KEY=DEMO_KEY

# NASA API timeout in seconds
NASA_API_TIMEOUT=10

# NASA API cache timeout in seconds (3600 = 1 hour)
NASA_API_CACHE_TIMEOUT=3600

# ===== EMAIL CONFIGURATION (Optional) =====

# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-specific-password
# DEFAULT_FROM_EMAIL=your-email@gmail.com

# ===== REDIS/CACHE CONFIGURATION (Optional) =====

# If using Redis for caching (recommended for production)
# REDIS_URL=redis://username:password@hostname:6379/0

# ===== LOGGING CONFIGURATION (Optional) =====

# Sentry for error tracking (optional)
# SENTRY_DSN=https://key@sentry.io/project-id

